FLASK_APP=app
FLASK_ENV=development
SECRET_KEY=change-me-in-production
DATABASE_URL=postgresql://evvents:evvents@db:5432/evvents
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# Email
APP_BASE_URL=http://localhost:5000
EMAIL_PROVIDER=console              # console | resend | mailgun | smtp
EMAIL_FROM=noreply@evvents.io
EMAIL_API_KEY=                      # required for resend/mailgun
EMAIL_SMTP_HOST=                    # required for smtp
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
